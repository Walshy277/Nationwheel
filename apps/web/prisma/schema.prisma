generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  LEADER
  JOURNALIST
  LORE
  ADMIN
  OWNER
}

enum RevisionFieldType {
  STATS
  WIKI
  FLAG
  ACTION
  LEADER_NAME
}

enum LoreActionStatus {
  CURRENT
  COMPLETED
  REQUIRES_SPIN
}

enum ReactionKind {
  LIKE
  SUPPORT
  CONCERN
  INSIGHT
}

model User {
  id                String             @id @default(cuid())
  name              String?
  email             String?            @unique
  discordId         String?            @unique
  emailVerified     DateTime?
  image             String?
  passwordHash      String?
  role              Role               @default(USER)
  roles             Role[]             @default([USER])
  leaderOf          Nation[]           @relation("NationLeader")
  wikiUpdates       NationWiki[]       @relation("WikiUpdatedBy")
  revisions         NationRevision[]   @relation("RevisionChangedBy")
  loreActions       LoreAction[]       @relation("LoreActionCreatedBy")
  loreActionUpdates LoreActionUpdate[] @relation("LoreActionUpdateCreatedBy")
  publicPageUpdates PublicLorePage[]   @relation("PublicPageUpdatedBy")
  newsPosts         WorldNewsPost[]    @relation("WorldNewsPostAuthor")
  newsReactions     WorldNewsReaction[]
  forumThreads      ForumThread[]      @relation("ForumThreadAuthor")
  forumPosts        ForumPost[]        @relation("ForumPostAuthor")
  forumReactions    ForumReaction[]
  leaderNotifications LeaderNotification[] @relation("LeaderNotificationCreatedBy")
  gameClockUpdates GameClock[] @relation("GameClockUpdatedBy")
  accounts          Account[]
  sessions          Session[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model Nation {
  id           String           @id @default(cuid())
  name         String
  slug         String           @unique
  people       String
  government   String
  gdp          String
  economy      String
  military     String
  overview     String?
  area         String?
  geoPoliticalStatus String?
  block        String?
  culture      String?
  hdi          String?
  flagImage    String?
  leaderName   String?
  leaderUserId String?
  leaderUser   User?            @relation("NationLeader", fields: [leaderUserId], references: [id])
  wiki         NationWiki?
  revisions    NationRevision[]
  loreActions  LoreAction[]
  notifications LeaderNotification[]
  sentMessages NationMessage[] @relation("NationMessageFrom")
  receivedMessages NationMessage[] @relation("NationMessageTo")
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

model NationWiki {
  id              String   @id @default(cuid())
  nationId        String   @unique
  nation          Nation   @relation(fields: [nationId], references: [id], onDelete: Cascade)
  content         String
  updatedByUserId String?
  updatedByUser   User?    @relation("WikiUpdatedBy", fields: [updatedByUserId], references: [id])
  updatedAt       DateTime @updatedAt
}

model NationRevision {
  id              String            @id @default(cuid())
  nationId        String
  nation          Nation            @relation(fields: [nationId], references: [id], onDelete: Cascade)
  fieldType       RevisionFieldType
  previousValue   Json
  newValue        Json
  changedByUserId String?
  changedByUser   User?             @relation("RevisionChangedBy", fields: [changedByUserId], references: [id])
  createdAt       DateTime          @default(now())
}

model LoreAction {
  id                 String             @id @default(cuid())
  nationId           String
  nation             Nation             @relation(fields: [nationId], references: [id], onDelete: Cascade)
  type               String
  action             String
  source             String?
  timeframe          String
  status             LoreActionStatus   @default(CURRENT)
  outcome            String?
  requiresSpinReason String?
  rygaaNotifiedAt    DateTime?
  createdByUserId    String?
  createdByUser      User?              @relation("LoreActionCreatedBy", fields: [createdByUserId], references: [id])
  updates            LoreActionUpdate[]
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
}

model LoreActionUpdate {
  id              String     @id @default(cuid())
  actionId        String
  action          LoreAction @relation(fields: [actionId], references: [id], onDelete: Cascade)
  content         String
  createdByUserId String?
  createdByUser   User?      @relation("LoreActionUpdateCreatedBy", fields: [createdByUserId], references: [id])
  createdAt       DateTime   @default(now())
}

model LeaderNotification {
  id              String   @id @default(cuid())
  nationId        String
  nation          Nation   @relation(fields: [nationId], references: [id], onDelete: Cascade)
  messageId       String?
  message         NationMessage? @relation(fields: [messageId], references: [id], onDelete: Cascade)
  title           String
  body            String
  href            String?
  readAt          DateTime?
  createdByUserId String?
  createdByUser   User?    @relation("LeaderNotificationCreatedBy", fields: [createdByUserId], references: [id])
  createdAt       DateTime @default(now())

  @@index([nationId, readAt, createdAt])
  @@index([messageId])
}

model NationMessage {
  id           String   @id @default(cuid())
  fromNationId String
  fromNation   Nation   @relation("NationMessageFrom", fields: [fromNationId], references: [id], onDelete: Cascade)
  toNationId   String
  toNation     Nation   @relation("NationMessageTo", fields: [toNationId], references: [id], onDelete: Cascade)
  serviceName  String   @default("Nation Wheel Postal Service")
  trackingCode String   @unique
  status       String   @default("DELIVERED")
  subject      String
  body         String
  readAt       DateTime?
  notifications LeaderNotification[]
  createdAt    DateTime @default(now())

  @@index([fromNationId, createdAt])
  @@index([toNationId, readAt, createdAt])
}

model GameClock {
  id              String   @id @default("current")
  day             Int      @default(21)
  year            Int      @default(4488)
  updatedByUserId String?
  updatedByUser   User?    @relation("GameClockUpdatedBy", fields: [updatedByUserId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model PublicLorePage {
  id              String   @id @default(cuid())
  key             String   @unique
  title           String
  content         String
  updatedByUserId String?
  updatedByUser   User?    @relation("PublicPageUpdatedBy", fields: [updatedByUserId], references: [id])
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())
}

model WorldNewsPost {
  id          String    @id @default(cuid())
  title       String
  summary     String
  content     String
  sourceLabel String?
  sourceUrl   String?
  authorId    String?
  author      User?     @relation("WorldNewsPostAuthor", fields: [authorId], references: [id])
  reactions   WorldNewsReaction[]
  publishedAt DateTime  @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([publishedAt])
}

model WorldNewsReaction {
  id        String       @id @default(cuid())
  postId    String
  post      WorldNewsPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind      ReactionKind
  createdAt DateTime     @default(now())

  @@unique([postId, userId, kind])
  @@index([postId, kind])
}

model ForumThread {
  id          String       @id @default(cuid())
  title       String
  slug        String       @unique
  category    String
  body        String
  isPinned    Boolean      @default(false)
  authorId    String
  author      User         @relation("ForumThreadAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  posts       ForumPost[]
  reactions   ForumReaction[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([category, updatedAt])
  @@index([authorId, createdAt])
}

model ForumPost {
  id        String       @id @default(cuid())
  threadId  String
  thread    ForumThread  @relation(fields: [threadId], references: [id], onDelete: Cascade)
  authorId  String
  author    User         @relation("ForumPostAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([threadId, createdAt])
  @@index([authorId, createdAt])
}

model ForumReaction {
  id        String       @id @default(cuid())
  threadId  String
  thread    ForumThread  @relation(fields: [threadId], references: [id], onDelete: Cascade)
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind      ReactionKind
  createdAt DateTime     @default(now())

  @@unique([threadId, userId, kind])
  @@index([threadId, kind])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

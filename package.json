{
  "name": "nation-wheel",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm --parallel --filter @nation-wheel/web --filter @nation-wheel/bot dev",
    "dev:web": "pnpm --filter @nation-wheel/web dev",
    "dev:bot": "pnpm --filter @nation-wheel/bot dev",
    "register:bot": "pnpm --filter @nation-wheel/bot register",
    "start:bot": "pnpm --filter @nation-wheel/bot start",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test:web": "pnpm --filter @nation-wheel/web exec tsx --test src/lib/navigation.test.ts src/lib/permissions.test.ts",
    "db:generate": "pnpm --filter @nation-wheel/web db:generate",
    "db:push": "pnpm --filter @nation-wheel/web db:push",
    "db:seed": "pnpm --filter @nation-wheel/web db:seed"
  },
  "dependencies": {
    "next": "16.2.4",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "playwright": "^1.59.1",
    "typescript": "^5.9.3",
    "vercel": "^51.8.0"
  }
}
